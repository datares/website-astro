---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
const carouselImages = [
  { src: "/assets/images/filler1.JPG", alt: "Carousel image 1" },
  { src: "/assets/images/filler3.jpg", alt: "Carousel image 3" },
  { src: "/assets/images/filler4.JPG", alt: "Carousel image 4" },
  { src: "/assets/images/filler5.jpg", alt: "Carousel image 5" },
];
const desc =
  "At DataRes, we solve problems and craft stories with data. We \
provide a platform for aspiring data scientists and analysts to collaborate on \
impactful data projects. If you love playing with data, creating \
powerful visualizations, or building predictive models, you have a home \
at DataRes.";
---

<BaseLayout title="UCLA DataRes" desc={desc}>
  <div class="w-full">
    <Hero color="bg-slate-900" invert fullBleed>
      <div class="grid w-full items-center gap-8 px-6 py-12 sm:px-8 sm:py-16 lg:grid-cols-[1.08fr_0.92fr] lg:px-12 lg:py-20 xl:px-16">
        <div class="flex h-full max-w-2xl flex-col justify-center py-4 lg:py-8">
          <h1 class="text-3xl font-bold tracking-tight text-white md:text-5xl xl:text-5xl">UCLA's largest data science community</h1>
          <p class="mt-5 text-base leading-relaxed text-white/90 md:text-lg xl:text-lg">
            DataRes is UCLA's largest data science community, with 120+ members across 5 subteams. From data journalism to startup consulting projects, DataRes engages with the data science community in and out of UCLA through hands-on projects, workshops, mentorship, and more.
          </p>
        </div>
        <img
          src="/assets/images/filler2.jpg"
          alt="DataRes carousel image"
          class="block w-full max-w-[60%] h-auto justify-self-center object-contain object-center"
        />
      </div>
    </Hero>

    <div class="mx-auto w-full max-w-[90rem] px-6 lg:px-12 py-20" id="about-community">
      <h1 class="text-center font-extrabold text-4xl md:text-5xl mb-10 text-slate-900">Our Community</h1>
      <div class="max-w-4xl mx-auto">
        <p class="text-lg md:text-xl leading-relaxed text-slate-700 text-center">
          DataRes invites aspiring data scientists from the UCLA community and beyond to grow together. Besides projects, we also have socials, a mentor-mentee program, and more initiatives to strengthen our community.
        </p>
      </div>

      <div class="mt-12 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="carousel-track py-6">
          {[...carouselImages, ...carouselImages].map((image, index) => (
            <div class="carousel-item px-4" aria-hidden={index >= carouselImages.length ? "true" : "false"}>
              <div class="h-32 md:h-40 w-52 md:w-64 rounded-xl border border-slate-200 bg-slate-50 overflow-hidden">
                <img src={image.src} alt={image.alt} class="h-full w-full object-cover" loading="lazy" />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .carousel-track {
    display: flex;
    width: max-content;
    animation: carousel-scroll 24s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .carousel-item {
    flex: 0 0 auto;
  }

  @keyframes carousel-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      animation: none;
    }
  }
</style>
